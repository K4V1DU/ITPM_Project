const mongoose = require("mongoose");

const reviewSchema = new mongoose.Schema(
  {
    reviewer: {
      type: mongoose.Schema.Types.ObjectId,
      ref: "User",
      required: true, 
    },

    accommodation: {
      type: mongoose.Schema.Types.ObjectId,
      ref: "Accommodation",
    },

    host: {
      type: mongoose.Schema.Types.ObjectId,
      ref: "User", 
    },

    comment: {
      type: String,
      trim: true,
      required: true,
    },

    rating: {
      type: Number,
      min: 1,
      max: 5,
      required: true,
    },

    images: [String], 
  },
  {
    timestamps: true, 
  }
);

module.exports = mongoose.models.Review || mongoose.model("Review", reviewSchema);
