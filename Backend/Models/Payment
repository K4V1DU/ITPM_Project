const mongoose = require("mongoose");

const PaymentSchema = new mongoose.Schema({
  host:             { type: mongoose.Schema.Types.ObjectId, ref: "User", required: true },
  listing:          { type: mongoose.Schema.Types.ObjectId, required: true },
  listingType:      { type: String, enum: ["food", "accommodation"], required: true },

  // Plan details
  plan:             { type: String, enum: ["1m", "3m", "6m", "12m"], required: true },
  amount:           { type: Number, required: true },
  daysAdded:        { type: Number, required: true },
  newExpireDate:    { type: Date },

  // Reference code — host uses this as bank transfer remark
  referenceCode:    { type: String, unique: true, required: true },


  status: {
    type: String,
    enum: ["created", "pending", "verified", "rejected", "manual_requested"],
    default: "created",
  },

  // Receipt (stored after upload step)
  receiptImage:     { type: Buffer },
  receiptMimeType:  { type: String },
  receiptUploadedAt:{ type: Date },

  // OCR extracted fields (sent from browser Tesseract)
  extractedAmount:  { type: Number },
  extractedRef:     { type: String },
  extractedDate:    { type: String },
  extractedBank:    { type: String },
  rawOcrText:       { type: String },
  amountMatched:    { type: Boolean },
  refMatched:       { type: Boolean },

  // User note (on manual request)
  note:             { type: String, default: "" },

  // Admin review
  adminNote:        { type: String },
  reviewedBy:       { type: mongoose.Schema.Types.ObjectId, ref: "User" },
  reviewedAt:       { type: Date },
}, { timestamps: true });

module.exports = mongoose.model("Payment", PaymentSchema);