const mongoose = require("mongoose");

const foodServiceSchema = new mongoose.Schema(
  {
    owner: {
      type: String,
      required: true,
    },

    kitchenName: {
      type: String,
      required: true,
      trim: true,
    },

    description: {
      type: String,
      trim: true,
    },

    address: {
      type: String,
      required: true,
    },

    operatingHours: {
      open: {
        type: String,
        default: "08:00 AM",
      },
      close: {
        type: String,
        default: "10:00 PM",
      },
    },

    serviceType: {
      type: String,
      enum: ["Home Kitchen", "Restaurant", "Cafe", "Bakery"],
      default: "Home Kitchen",
    },

    deliveryAvailable: {
      type: Boolean,
      default: true,
    },

    pickupAvailable: {
      type: Boolean,
      default: true,
    },

    menu: [
      {
        type: mongoose.Schema.Types.ObjectId,
        ref: "MenuItem",
      },
    ],

    iconImage: {
      type: mongoose.Schema.Types.ObjectId,
      ref: "Photo",
    },
    
    BackgroundImage: {
      type: mongoose.Schema.Types.ObjectId,
      ref: "Photo",
    },

    reviews: [
      {
        type: mongoose.Schema.Types.ObjectId,
        ref: "Review",
      },
    ],

    ratingAverage: {
      type: Number,
      default: 0,
    },

    ratingCount: {
      type: Number,
      default: 0,
    },

    location: {
      type: {
        type: String,
        enum: ["Point"],
        default: "Point",
      },
      coordinates: {
        type: [Number],
        required: true,
      },
    },

    isAvailable: {
      type: Boolean,
      default: false,
    },

    expireDate: {
      type: Date,
    },
  },
  { timestamps: true },
);

foodServiceSchema.index({ location: "2dsphere" });

module.exports =
  mongoose.models.FoodService ||
  mongoose.model("FoodService", foodServiceSchema);
