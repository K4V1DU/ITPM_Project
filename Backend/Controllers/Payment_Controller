const Payment       = require("../models/Payment");
const FoodService   = require("../models/FoodService");
const Accommodation = require("../models/Accommodation");

// ─── Plan Config ─────────────────────────────────────────────────────────────
const PLANS = {
  "1m":  { label: "1 Month",   amount: 299,  daysAdded: 30  },
  "3m":  { label: "3 Months",  amount: 799,  daysAdded: 90  },
  "6m":  { label: "6 Months",  amount: 1499, daysAdded: 180 },
  "12m": { label: "12 Months", amount: 2599, daysAdded: 365 },
};

// ─── Helper: Generate unique REF code ────────────────────────────────────────
const generateReferenceCode = async () => {
  let referenceCode;
  let exists = true;
  while (exists) {
    const randomNum = Math.floor(1000 + Math.random() * 90000);
    referenceCode = `REF${randomNum}`;
    exists = await Payment.exists({ referenceCode });
  }
  return referenceCode;
};

// ─── Helper: Calculate new expireDate ────────────────────────────────────────
// If current expireDate is in the future  → add days FROM that date
// If current expireDate is in the past    → add days FROM today
const calcNewExpireDate = (currentExpireDate, daysAdded) => {
  const now      = new Date();
  const baseDate = currentExpireDate && new Date(currentExpireDate) > now
    ? new Date(currentExpireDate)   // still valid — extend from current expiry
    : new Date();                   // expired or never set — start from today

  baseDate.setDate(baseDate.getDate() + daysAdded);
  return baseDate;
};

// ─── Helper: Apply expireDate to the listing ──────────────────────────────────
// Matches the exact pattern used in Review_Controller:
//   FoodService.findByIdAndUpdate(foodService, { $push: { reviews: review._id } })
//   — no options, uses $set operator explicitly
const applyExpireDateToListing = async (listingId, listingType, daysAdded) => {
  const Model      = listingType === "food" ? FoodService : Accommodation;
  const listingStr = listingId?.toString();

  // 1. Fetch current expireDate to calculate the new one
  const listing = await Model.findById(listingStr).select("expireDate");
  if (!listing) throw new Error(`Listing not found — id: ${listingStr}, type: ${listingType}`);

  const newExpireDate = calcNewExpireDate(listing.expireDate, daysAdded);

  // 2. Use $set with no options — same pattern as Review_Controller
  await Model.findByIdAndUpdate(listingStr, {
    $set: {
      expireDate:  newExpireDate,
      isAvailable: true,
    },
  });

  console.log(`✅ ${listingType} ${listingStr} → expireDate: ${newExpireDate}, isAvailable: true`);
  return newExpireDate;
};

// ─── GET /Payment/plans ───────────────────────────────────────────────────────
exports.getPlans = (req, res) => {
  const plans = Object.entries(PLANS).map(([key, val]) => ({ key, ...val }));
  res.json({ success: true, plans });
};

// ─── POST /Payment/create ─────────────────────────────────────────────────────
// Body: { hostId, listingId, listingType, plan }
exports.createPayment = async (req, res) => {
  try {
    const { hostId, listingId, listingType, plan } = req.body;

    if (!hostId)                                          return res.status(400).json({ success: false, message: "hostId is required." });
    if (!PLANS[plan])                                     return res.status(400).json({ success: false, message: "Invalid plan selected." });
    if (!["food", "accommodation"].includes(listingType)) return res.status(400).json({ success: false, message: "Invalid listing type." });
    if (!listingId)                                       return res.status(400).json({ success: false, message: "listingId is required." });

    const { amount, daysAdded } = PLANS[plan];

    // Preview expireDate (recalculated on actual verify — this is just for display)
    const Model   = listingType === "food" ? FoodService : Accommodation;
    const listing = await Model.findById(listingId).select("expireDate");
    const previewExpireDate = calcNewExpireDate(listing?.expireDate, daysAdded);

    const referenceCode = await generateReferenceCode();

    const payment = await Payment.create({
      host:          hostId,
      listing:       listingId,
      listingType,
      plan,
      amount,
      daysAdded,
      newExpireDate: previewExpireDate,
      referenceCode,
      status:        "created",
    });

    res.status(201).json({
      success: true,
      message: "Payment record created. Please transfer the amount using your reference code.",
      payment: {
        _id:           payment._id,
        referenceCode: payment.referenceCode,
        plan:          payment.plan,
        amount:        payment.amount,
        daysAdded:     payment.daysAdded,
        newExpireDate: payment.newExpireDate,
        status:        payment.status,
        createdAt:     payment.createdAt,
      },
    });
  } catch (err) {
    console.error("createPayment error:", err);
    res.status(500).json({ success: false, message: "Server error.", error: err.message });
  }
};

// ─── GET /Payment/my?hostId=xxx ───────────────────────────────────────────────
exports.getMyPayments = async (req, res) => {
  try {
    const { hostId } = req.query;
    if (!hostId) return res.status(400).json({ success: false, message: "hostId is required." });

    const payments = await Payment.find({ host: hostId })
      .sort({ createdAt: -1 })
      .select("-receiptImage -rawOcrText");

    res.json({ success: true, payments });
  } catch (err) {
    console.error("getMyPayments error:", err);
    res.status(500).json({ success: false, message: "Server error.", error: err.message });
  }
};

// ─── GET /Payment/:id?hostId=xxx ─────────────────────────────────────────────
exports.getPaymentById = async (req, res) => {
  try {
    const { hostId } = req.query;
    const payment = await Payment.findOne({
