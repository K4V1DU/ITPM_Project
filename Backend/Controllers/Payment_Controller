  } catch (err) {
    console.error("getPaymentById error:", err);
    res.status(500).json({ success: false, message: "Server error.", error: err.message });
  }
};

// ─── POST /Payment/:id/upload-receipt ────────────────────────────────────────
// Body (multipart): receipt image + OCR fields
exports.uploadReceipt = async (req, res) => {
  try {
    const payment = await Payment.findById(req.params.id);
    if (!payment) return res.status(404).json({ success: false, message: "Payment not found." });

    if (["verified", "manual_requested"].includes(payment.status)) {
      return res.status(400).json({ success: false, message: `Payment is already ${payment.status}.` });
    }

    const { extractedAmount, extractedRef, extractedDate, extractedBank, rawOcrText } = req.body;

    const parsedAmount = parseFloat(extractedAmount) || 0;

    // ── Verification logic ────────────────────────────────────────────────────
    // Exact match only — OCR must read the number correctly, no tolerance
    // If OCR reads 2,589 instead of 2,599 that is an OCR failure → manual review
    const amountMatched = parsedAmount === payment.amount;
    const refMatched    = extractedRef
      ? extractedRef.toUpperCase().includes(payment.referenceCode.toUpperCase())
      : false;

    const newStatus = (amountMatched && refMatched) ? "verified" : "pending";

    // ── Always log so we can debug ────────────────────────────────────────────
    console.log("─── uploadReceipt debug ───────────────────────────────");
    console.log("  paymentId    :", req.params.id);
    console.log("  listingId    :", payment.listing?.toString());
    console.log("  listingType  :", payment.listingType);
    console.log("  daysAdded    :", payment.daysAdded);
    console.log("  expected amt :", payment.amount, "| extracted:", parsedAmount, "| matched:", amountMatched);
    console.log("  expected ref :", payment.referenceCode, "| extracted:", extractedRef, "| matched:", refMatched);
    console.log("  → newStatus  :", newStatus);
    console.log("───────────────────────────────────────────────────────");

    // ── If verified → update expireDate on the listing ───────────────────────
    let finalExpireDate = payment.newExpireDate;
    if (newStatus === "verified") {
      console.log("🔄 Verifying payment — updating listing...");
      console.log("   listingId   :", payment.listing);
      console.log("   listingType :", payment.listingType);
      console.log("   daysAdded   :", payment.daysAdded);

      const Model = payment.listingType === "food" ? FoodService : Accommodation;
      const before = await Model.findById(payment.listing).select("expireDate isAvailable");
      console.log("   listing found:", before ? "YES" : "NO — ID mismatch or wrong model");
      if (before) console.log("   current expireDate:", before.expireDate);

      finalExpireDate = await applyExpireDateToListing(
        payment.listing,
        payment.listingType,
        payment.daysAdded,
      );
      console.log(`✅ Done — new expireDate: ${finalExpireDate}`);
    }

    // ── Save receipt + OCR data ───────────────────────────────────────────────
    const updateData = {
      status:            newStatus,
      receiptUploadedAt: new Date(),
      extractedAmount:   parsedAmount,
      extractedRef:      extractedRef  || "",
      extractedDate:     extractedDate || "",
      extractedBank:     extractedBank || "",
      rawOcrText:        rawOcrText    || "",
      amountMatched,
      refMatched,
      newExpireDate:     finalExpireDate,
    };

    if (req.file) {
      updateData.receiptImage    = req.file.buffer;
      updateData.receiptMimeType = req.file.mimetype;
    }

    const updated = await Payment.findByIdAndUpdate(req.params.id, updateData, { returnDocument: 'after' })
      .select("-receiptImage -rawOcrText");

    res.json({
      success: true,
      message: newStatus === "verified"
        ? "Payment verified! Your listing is now active."
        : "Receipt uploaded. Verification failed — you may request manual review.",
      payment:      updated,
      verification: { amountMatched, refMatched, newStatus, newExpireDate: finalExpireDate },
    });
  } catch (err) {
    console.error("uploadReceipt error:", err);
    res.status(500).json({ success: false, message: "Server error.", error: err.message });
  }
};

// ─── PATCH /Payment/:id/manual-request ───────────────────────────────────────
// Body: { note }
exports.requestManualReview = async (req, res) => {
  try {
    const payment = await Payment.findById(req.params.id);
    if (!payment) return res.status(404).json({ success: false, message: "Payment not found." });

    if (payment.status === "verified")          return res.status(400).json({ success: false, message: "Payment is already verified." });
    if (payment.status === "manual_requested")  return res.status(400).json({ success: false, message: "Manual review already requested." });
    if (!["pending", "created"].includes(payment.status)) {
      return res.status(400).json({ success: false, message: `Cannot request manual review for status "${payment.status}".` });
    }

    const updated = await Payment.findByIdAndUpdate(
      req.params.id,
      { status: "manual_requested", note: req.body.note || "" },
      { returnDocument: 'after' },
    ).select("-receiptImage -rawOcrText");

    res.json({
      success: true,
      message: "Manual review requested. An admin will verify your payment within 24 hours.",
      payment: updated,
    });
  } catch (err) {
    console.error("requestManualReview error:", err);
    res.status(500).json({ success: false, message: "Server error.", error: err.message });
  }
};

// ─── PATCH /Payment/:id/cancel ────────────────────────────────────────────────
// Body: { hostId }
exports.cancelPayment = async (req, res) => {
  try {
    const { hostId } = req.body;
    const payment = await Payment.findOne({ _id: req.params.id, host: hostId });

    if (!payment) return res.status(404).json({ success: false, message: "Payment not found." });

    if (payment.status !== "created") {
      return res.status(400).json({
        success: false,
        message: `Cannot cancel a payment with status "${payment.status}".`,
      });
    }

    await Payment.deleteOne({ _id: payment._id });
    res.json({ success: true, message: "Payment cancelled and removed." });
  } catch (err) {
    console.error("cancelPayment error:", err);
    res.status(500).json({ success: false, message: "Server error.", error: err.message });
  }
};