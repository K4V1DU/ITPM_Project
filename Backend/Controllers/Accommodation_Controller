const Accommodation = require("../models/Accommodation");

// ---------------------------
// Add New Accommodation
// ---------------------------
const addAccommodation = async (req, res) => {
  try {
    const {
      owner,
      title,
      description,
      address,
      location,
      pricePerMonth,
      bedrooms,
      beds,
      bathrooms,
      amenities,
      rules,
      genderPreference,
    } = req.body;

    const accommodation = new Accommodation({
      owner,
      title,
      description,
      address,
      location,
      pricePerMonth,
      bedrooms,
      beds,
      bathrooms,
      amenities,
      rules,
      genderPreference,
    });

    await accommodation.save();

    res.status(201).json({ success: true, accommodation });
  } catch (err) {
    console.error(err);
    res.status(500).json({ success: false, message: "Failed to create accommodation" });
  }
};

module.exports = {
  Accommodation,
  addAccommodation
};